# Supabase project — Project Settings → API in your Supabase dashboard.
# SUPABASE_SERVICE_ROLE_KEY bypasses Row Level Security and must only ever be read
# server-side (see src/lib/supabase-client.ts) — never prefix it with VITE_ or reference
# it from client code, or it will end up in the browser bundle.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Google Custom Search JSON API — used to automatically find a product photo when one
# isn't uploaded manually (see src/lib/image-search-api.ts). Both are free to create:
#   1. GOOGLE_CSE_API_KEY — Google Cloud Console → APIs & Services → Credentials → Create
#      API key, with the "Custom Search API" enabled on the project.
#   2. GOOGLE_CSE_ID — programmablesearchengine.google.com → Add → turn on "Image search"
#      and "Search the entire web" (or restrict "Sites to search" to specific Maldivian
#      retailer sites to bias results toward local products) → copy the Search engine ID.
# Free tier is 100 searches/day; leave blank to disable auto photo lookup (products will
# just keep using the placeholder image until one is uploaded manually).
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Resend (resend.com) — sends the "Forgot Password" reset-link email (see
# src/lib/password-reset-server-store.ts). Both are free to set up:
#   1. RESEND_API_KEY — resend.com → API Keys → Create API Key.
#   2. RESEND_FROM_EMAIL — the "from" address for reset emails. On Resend's free tier
#      without a verified domain, use their shared sandbox address ("onboarding@resend.dev");
#      once you verify your own domain (Resend → Domains), use an address on that domain.
# Free tier is 100 emails/day; leave blank to disable — users will see a message asking
# them to have an Admin or Super Admin reset their password instead (Admin > Users).
RESEND_API_KEY=
RESEND_FROM_EMAIL=
